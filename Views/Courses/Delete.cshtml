@model GradeFlow.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4 border-danger">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h4 class="fw-bold mb-3 text-danger">
                <i class="bi bi-exclamation-triangle-fill"></i> Delete Course
            </h4>
        </div>
        <div class="card-body">
            <div class="alert alert-danger d-flex align-items-center" role="alert">
                <i class="bi bi-exclamation-octagon-fill me-2 fs-4"></i>
                <div>
                    <strong>Warning!</strong> Are you sure you want to delete this course? This action cannot be undone.
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-4 fw-semibold">Title</dt>
                        <dd class="col-sm-8">@Model.Title</dd>

                        <dt class="col-sm-4 fw-semibold">Course Code</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary bg-opacity-10 text-dark">@Model.Code</span>
                        </dd>

                        <dt class="col-sm-4 fw-semibold">Instructor</dt>
                        <dd class="col-sm-8">@Model.Instructor?.Email</dd>

                        <dt class="col-sm-4 fw-semibold">Term</dt>
                        <dd class="col-sm-8">@Model.Term</dd>
                    </dl>
                </div>
                <div class="col-md-6 d-none d-md-block">
                    <div class="bg-light rounded-4 p-3 text-center">
                        <i class="bi bi-trash3 text-danger" style="font-size: 4rem;"></i>
                        <p class="text-muted small mt-2">Deleting will also remove all assignments and submissions.</p>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" class="mt-3">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="bi bi-trash"></i> Confirm Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
        <div class="card-footer bg-white border-top-0 pb-4 pt-0">
            <small class="text-muted">
                <i class="bi bi-info-circle"></i> Deleted data cannot be recovered.
            </small>
        </div>
    </div>
</div>
