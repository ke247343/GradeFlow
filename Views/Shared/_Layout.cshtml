<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GradeFlow</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm">
            <div class="container">
                <!-- Brand Anchor consistently maps back to global system root landing -->
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-journal-bookmark-fill"></i> GradeFlow
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">

                        <!-- DYNAMIC CONTEXTUAL HOME NAVIGATION CONTROLLER -->
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold text-dark" asp-controller="Admin" asp-action="Dashboard">
                                        <i class="bi bi-speedometer2 text-danger"></i> Admin Dashboard
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Instructor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold text-dark" asp-controller="Courses" asp-action="Index">
                                        <i class="bi bi-house-door text-primary"></i> Faculty Workspace
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link fw-semibold text-dark" asp-controller="Home" asp-action="MyGrades">
                                        <i class="bi bi-grid-1x2 text-success"></i> Student Portal
                                    </a>
                                </li>
                            }
                        }
                        else
                        {
                            // Fallback link shown exclusively to unauthenticated visitor sessions
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                        }

                        <!-- Global Reference Module Directories Links -->
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Courses" asp-action="Index">Courses Directory</a>
                        </li>

                        @if (User.IsInRole("Instructor"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="instructorDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Management Tools
                                </a>
                                <ul class="dropdown-menu border-0 shadow-sm rounded-3" aria-labelledby="instructorDropdown">
                                    <li><a class="dropdown-item small" asp-controller="Courses" asp-action="Index"><i class="bi bi-list-task"></i> Assigned Courses</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    System Governance
                                </a>
                                <ul class="dropdown-menu border-0 shadow-sm rounded-3" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item small" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-pie-chart"></i> Metrics Console</a></li>
                                    <li><a class="dropdown-item small" asp-controller="Admin" asp-action="Users"><i class="bi bi-shield-lock"></i> Identity Control</a></li>
                                    <li><a class="dropdown-item small" asp-controller="Admin" asp-action="Courses"><i class="bi bi-collection"></i> Course Directory</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item small text-danger" asp-controller="Admin" asp-action="TrashCan"><i class="bi bi-trash3"></i> Recovery Center</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <!-- FIXED SYSTEM TOAST ALERTS OVERLAY LAYER CONTAINER -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 2000; margin-top: 60px;">
        @if (TempData["Success"] != null)
        {
            <div id="systemSuccessToast" class="toast align-items-center text-white bg-success border-0 shadow-lg rounded-3" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill fs-5"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div id="systemErrorToast" class="toast align-items-center text-white bg-danger border-0 shadow-lg rounded-3" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-octagon-fill fs-5"></i>
                        <span>@TempData["Error"]</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>

    <main class="py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer bg-white border-top text-muted small py-3 mt-auto">
        <div class="container text-center">
            &copy; @DateTime.Now.Year GradeFlow – Smart Assignment Portal
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script type="text/javascript">
        document.addEventListener("DOMContentLoaded", function () {
            var successNode = document.getElementById('systemSuccessToast');
            if (successNode) {
                var toast = new bootstrap.Toast(successNode, { delay: 4000 });
                toast.show();
            }
            var errorNode = document.getElementById('systemErrorToast');
            if (errorNode) {
                var toast = new bootstrap.Toast(errorNode, { delay: 4000 });
                toast.show();
            }
        });
    </script>
</body>
</html>
