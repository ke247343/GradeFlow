@model IEnumerable<GradeFlow.Controllers.AdminCourseViewModel>

@{
    ViewData["Title"] = "Course Overview";
}

<div class="container">
    <h2 class="mb-4"><i class="bi bi-journal-bookmark-fill"></i> Course Overview</h2>
    <p class="text-muted">All courses in the system – instructor, enrollment count, assignments.</p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Title</th>
                        <th>Instructor</th>
                        <th>Term</th>
                        <th>Enrollments</th>
                        <th>Assignments</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@course.Code</span></td>
                            <td>@course.Title</td>
                            <td>@course.InstructorEmail</td>
                            <td>@course.Term</td>
                            <td><span class="badge bg-info">@course.EnrollmentCount</span></td>
                            <td><span class="badge bg-success">@course.AssignmentCount</span></td>
                            <td>
                                <a asp-controller="Courses" asp-action="Edit" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-controller="Courses" asp-action="Delete" asp-route-id="@course.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                                <a asp-controller="Assignments" asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-file-text"></i> Assignments
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
