@{
    ViewData["Title"] = "Admin Dashboard";
    dynamic stats = Model;
}

<div class="container">
    <h2 class="mb-4"><i class="bi bi-speedometer2"></i> Admin Dashboard</h2>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-people fs-1 text-primary"></i>
                    <h3 class="mt-2">@stats.TotalUsers</h3>
                    <p class="text-muted">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-book fs-1 text-success"></i>
                    <h3 class="mt-2">@stats.TotalCourses</h3>
                    <p class="text-muted">Courses</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-file-text fs-1 text-warning"></i>
                    <h3 class="mt-2">@stats.TotalAssignments</h3>
                    <p class="text-muted">Assignments</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <i class="bi bi-cloud-upload fs-1 text-info"></i>
                    <h3 class="mt-2">@stats.TotalSubmissions</h3>
                    <p class="text-muted">Submissions</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <i class="bi bi-graph-up"></i> Average Grade
                </div>
                <div class="card-body text-center">
                    <h2 class="display-4">@stats.AverageGrade.ToString("0.0")</h2>
                    <small>out of max points per assignment</small>
                </div>
            </div>
        </div>
    </div>
</div>
