@model IEnumerable<GradeFlow.Models.AdminCourseViewModel>
@{
    ViewData["Title"] = "Course Overview";
}

<div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-2">
            <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary rounded-circle p-2 border-0">
                <i class="bi bi-arrow-left fs-5 leading-none"></i>
            </a>
            <div>
                <small class="text-muted text-uppercase tracking-wider fw-bold">Platform Status</small>
                <h2 class="fw-bold m-0 text-dark">Global Syllabus Course Directory</h2>
            </div>
        </div>
        <div class="text-muted small">
            <i class="bi bi-collection-play-fill text-primary"></i> Academic Track Monitor
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-center small">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 text-start">Course Code</th>
                            <th class="text-start">Module Title Name</th>
                            <th>Assigned Faculty Instructor</th>
                            <th>Term Session</th>
                            <th>Active Rosters</th>
                            <th class="pe-4">Task Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <!-- OPTIMIZATION: Empty state fallback to ensure clean UI boundaries -->
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-minus display-6 d-block mb-2 text-opacity-50"></i>
                                    <span class="fw-semibold d-block">No Academic Modules Found</span>
                                    <small class="text-muted">There are no active or registered course tracks present on the platform.</small>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var course in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-start">
                                        <span class="badge bg-light border text-dark font-monospace fw-bold">@course.Code</span>
                                    </td>
                                    <td class="text-start fw-bold text-dark">@course.Title</td>
                                    <td class="text-muted">@course.InstructorEmail</td>
                                    <td>@course.Term</td>
                                    <td>
                                        <span class="badge bg-info bg-opacity-10 text-info fw-bold px-2.5 py-1.5">
                                            @course.EnrollmentCount Students
                                        </span>
                                    </td>
                                    <td class="pe-4 font-monospace fw-bold text-secondary">
                                        @course.AssignmentCount Tasks
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
