@model GradeFlow.Models.Course
@inject GradeFlow.Data.ApplicationDbContext _context
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@{
    ViewData["Title"] = $"{Model.Code} - Details";
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var currentUtc = DateTime.UtcNow;

    // Load assignments based on role visibility constraints
    var rawAssignments = _context.Assignments
        .Where(a => a.CourseId == Model.Id)
        .OrderBy(a => a.DueDate)
        .ToList();

    // Students only see assignments that have passed their Release Date
    var courseAssignments = User.IsInRole("Student")
        ? rawAssignments.Where(a => currentUtc >= a.ReleaseDate).ToList()
        : rawAssignments;

    var classAnnouncements = _context.Announcements
        .Where(ann => ann.CourseId == Model.Id)
        .OrderByDescending(ann => ann.CreatedAt)
        .ToList();
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-2">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-circle p-2 border-0">
            <i class="bi bi-arrow-left fs-5 leading-none"></i>
        </a>
        <div>
            <small class="text-muted text-uppercase tracking-wider fw-bold">Course Workspace</small>
            <h2 class="fw-bold m-0 text-dark">@Model.Code: @Model.Title</h2>
        </div>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
    {
        <a asp-controller="Grades" asp-action="Gradebook" asp-route-courseId="@Model.Id" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-grid-3x3-gap"></i> Open Class Gradebook
        </a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4">@TempData["Error"]</div>
}

<div class="row g-4">
    <!-- LEFT SIDEBAR: Metadata, Announcements, and Bulletins -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">Information Overview</h5>
                <dl class="row mb-0 g-2 small">
                    <dt class="col-sm-4 text-muted font-normal">Term</dt>
                    <dd class="col-sm-8 fw-semibold text-dark">@Model.Term</dd>

                    <dt class="col-sm-4 text-muted font-normal">Instructor</dt>
                    <dd class="col-sm-8 fw-semibold text-dark text-truncate">@Model.Instructor?.Email</dd>
                </dl>

                @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                {
                    <div class="d-flex gap-2 mt-4 border-top pt-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-warning w-100 rounded-pill">
                            <i class="bi bi-pencil"></i> Modify Course
                        </a>
                        <a asp-action="Enroll" asp-route-id="@Model.Id" class="btn btn-sm btn-primary w-100 rounded-pill shadow-sm">
                            <i class="bi bi-person-plus"></i> Enroll Student
                        </a>
                    </div>
                }
            </div>
        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 text-dark border-bottom pb-2"><i class="bi bi-megaphone text-danger"></i> Dispatch Class Bulletin</h5>
                    <form asp-controller="Announcements" asp-action="Create" method="post">
                        <input type="hidden" name="courseId" value="@Model.Id" />
                        <div class="mb-2">
                            <input type="text" name="title" class="form-control form-control-sm" placeholder="Bulletin Subject Title" required />
                        </div>
                        <div class="mb-3">
                            <textarea name="content" class="form-control form-control-sm" rows="3" placeholder="Compose alert notifications..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-sm btn-danger w-100 rounded-pill">Deploy Broadcast</button>
                    </form>
                </div>
            </div>
        }

        <!-- Broadcast Bulletins Feed Panel -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-0">
                <h5 class="fw-bold m-0 text-dark"><i class="bi bi-chat-square-text text-info"></i> News Bulletin Feed</h5>
            </div>
            <div class="card-body p-4 pt-2">
                @if (classAnnouncements.Any())
                {
                    <div class="overflow-auto" style="max-height: 280px;">
                        @foreach (var news in classAnnouncements)
                        {
                            <div class="p-3 bg-light rounded-3 mb-2 border-start border-4 border-info">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="text-dark small text-truncate" style="max-width:160px;">@news.Title</strong>
                                    <small class="text-muted" style="font-size:0.7rem;">@news.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</small>
                                </div>
                                <p class="text-muted small m-0 text-break">@news.Content</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-3 border border-dashed rounded-3 bg-light bg-opacity-50">
                        <p class="text-muted small m-0">No announcements posted for this course yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL: Dynamic Multi-Role Assessment Matrix -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-2 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold m-0 text-dark">
                    <i class="bi bi-journal-text text-success"></i> Course Workwork & Assessments
                </h5>
                @if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                {
                    <a asp-controller="Assignments" asp-action="Create" asp-route-courseId="@Model.Id" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">
                        <i class="bi bi-plus-lg"></i> Create Assignment
                    </a>
                }
            </div>

            <div class="card-body p-4 pt-2">
                @if (courseAssignments.Any())
                {
                    <div class="table-responsive border rounded-3">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Assignment Details</th>
                                    @if (User.IsInRole("Instructor") || User.IsInRole("Admin"))
                                    {
                                        <th>Release Window</th>
                                        <th>Due Date Target</th>
                                        <th class="pe-3 text-end">Evaluation Hub</th>
                                    }
                                    else
                                    {
                                        <th>Target Deadline</th>
                                        <th>Submission Status</th>
                                        <th class="pe-3 text-end">Action Panel</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var assignment in courseAssignments)
                                {
                                    if (User.IsInRole("Admin") || User.IsInRole("Instructor"))
                                    {
                                        var queueCount = _context.Submissions.Count(s => s.AssignmentId == assignment.Id && !s.Grade.HasValue);
                                        <tr>
                                            <td class="ps-3">
                                                <span class="fw-bold text-dark d-block">@assignment.Title</span>
                                                <span class="badge bg-light border text-dark font-normal" style="font-size: 0.7rem;">@assignment.Category - Max: @assignment.MaxPoints pts</span>
                                            </td>
                                            <td>
                                                @if (currentUtc < assignment.ReleaseDate)
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1">Scheduled</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success px-2 py-1">Live</span>
                                                }
                                            </td>
                                            <td>
                                                @if (currentUtc > assignment.CutOffDate)
                                                {
                                                    <span class="badge bg-secondary text-white px-2 py-1">Locked</span>
                                                }
                                                else
                                                {
                                                    <span class="text-dark fw-medium">@assignment.DueDate.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                                                }
                                            </td>
                                            <td class="pe-3 text-end">
                                                <a asp-controller="Grades" asp-action="Index" asp-route-assignmentId="@assignment.Id" class="btn btn-sm btn-primary rounded-3 position-relative px-3">
                                                    <i class="bi bi-clipboard-check"></i> Submissions
                                                    @if (queueCount > 0)
                                                    {
                                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white">@queueCount</span>
                                                    }
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        // STUDENT SPECIFIC PRESENTATION ROW LAYOUT
                                        var submission = _context.Submissions.FirstOrDefault(s => s.AssignmentId == assignment.Id && s.StudentId == userId);
                                        <tr>
                                            <td class="ps-3">
                                                <span class="fw-bold text-dark d-block">@assignment.Title</span>
                                                <span class="badge bg-light border text-dark font-normal" style="font-size: 0.7rem;">@assignment.Category - Max: @assignment.MaxPoints pts</span>
                                            </td>
                                            <td class="text-muted">@assignment.DueDate.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                                            <td>
                                                @if (submission != null)
                                                {
                                                    if (submission.Grade.HasValue)
                                                    {
                                                        <span class="badge bg-success text-white px-2.5 py-1">Graded: @submission.Grade / @assignment.MaxPoints</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-info bg-opacity-10 text-info px-2.5 py-1">Submitted (Pending Review)</span>
                                                    }
                                                }
                                                else if (currentUtc > assignment.CutOffDate)
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2.5 py-1"><i class="bi bi-lock-fill"></i> Missed (Closed)</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning px-2.5 py-1">Not Submitted</span>
                                                }
                                            </td>
                                            <td class="pe-3 text-end">
                                                @if (submission == null && currentUtc <= assignment.CutOffDate)
                                                {
                                                    <a asp-controller="Submissions" asp-action="Create" asp-route-assignmentId="@assignment.Id" class="btn btn-sm btn-success rounded-3 px-3">
                                                        <i class="bi bi-cloud-arrow-up"></i> Submit
                                                    </a>
                                                }
                                                else if (submission != null && !submission.Grade.HasValue && currentUtc <= assignment.CutOffDate)
                                                {
                                                    <a asp-controller="Submissions" asp-action="Create" asp-route-assignmentId="@assignment.Id" class="btn btn-sm btn-outline-secondary rounded-3 px-3">
                                                        Re-submit
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-light rounded-3 px-3 text-muted" disabled>Locked</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 border border-dashed rounded-3 bg-light bg-opacity-50 my-2">
                        <i class="bi bi-journal-code text-muted display-6"></i>
                        <h5 class="mt-2 fw-bold text-dark">No Coursework Assigned</h5>
                        <p class="text-muted small m-0">There are no open or active assessments assigned to this module view currently.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
