@model GradeFlow.Models.Assignment

@{
    ViewData["Title"] = "Edit Assignment";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h4 class="fw-bold mb-3">
                <i class="bi bi-pencil-square text-warning"></i> Modify Assignment Parameters
            </h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-7">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CourseId" />

                        <div class="form-group mb-3">
                            <label asp-for="Title" class="form-label fw-semibold"><i class="bi bi-type"></i> Assignment Title</label>
                            <input asp-for="Title" class="form-control" required />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Description" class="form-label fw-semibold"><i class="bi bi-card-text"></i> Rubric Description</label>
                            <textarea asp-for="Description" class="form-control p-3" rows="4">@Model.Description</textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- RECOMMENDATION 2 CRITICAL DESIGN: Chronological parameters mutation frame -->
                        <div class="row g-2 mb-3">
                            <div class="col-md-4">
                                <label asp-for="ReleaseDate" class="form-label fw-semibold small text-muted"><i class="bi bi-eye"></i> Edit Release</label>
                                <input asp-for="ReleaseDate" class="form-control form-control-sm" type="datetime-local" value="@Model.ReleaseDate.ToString("yyyy-MM-ddTHH:mm")" required />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="DueDate" class="form-label fw-semibold small text-muted"><i class="bi bi-calendar-event"></i> Edit Due Date</label>
                                <input asp-for="DueDate" class="form-control form-control-sm" type="datetime-local" value="@Model.DueDate.ToString("yyyy-MM-ddTHH:mm")" required />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="CutOffDate" class="form-label fw-semibold small text-muted"><i class="bi bi-lock"></i> Edit Cutoff</label>
                                <input asp-for="CutOffDate" class="form-control form-control-sm" type="datetime-local" value="@Model.CutOffDate.ToString("yyyy-MM-ddTHH:mm")" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="MaxPoints" class="form-label fw-semibold"><i class="bi bi-award"></i> Scale Points Cap</label>
                                <input asp-for="MaxPoints" class="form-control" required />
                                <span asp-validation-for="MaxPoints" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="AllowedFileTypes" class="form-label fw-semibold"><i class="bi bi-file-earmark-code"></i> Formats List</label>
                                <input asp-for="AllowedFileTypes" class="form-control font-monospace" required />
                                <span asp-validation-for="AllowedFileTypes" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 border-top pt-3">
                            <button type="submit" class="btn btn-warning rounded-pill px-4 shadow-sm text-dark fw-bold">Save Parameter Changes</button>
                            <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-secondary rounded-pill px-4">Cancel</a>
                        </div>
                    </form>
                </div>
                <div class="col-md-5 d-none d-md-block">
                    <div class="bg-light rounded-4 p-4 text-center h-100 d-flex flex-column justify-content-center">
                        <i class="bi bi-arrow-clockwise text-warning display-3 mb-2"></i>
                        <h6 class="fw-bold text-dark">Data Mutator Core Alert</h6>
                        <p class="text-muted small px-3">Altering time bounds will instantly refresh student dashboard permission locks across existing and active tracks in runtime.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
