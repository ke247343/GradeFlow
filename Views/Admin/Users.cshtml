@model IEnumerable<GradeFlow.Controllers.UserRoleViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container">
    <h2 class="mb-4"><i class="bi bi-people"></i> User Management</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Current Role</th>
                        <th>Change Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge bg-primary">@user.CurrentRole</span>
                            </td>
                            <td>
                                <form asp-action="AssignRole" method="post" class="d-flex gap-2">
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <select name="role" class="form-select form-select-sm w-auto">
                                        <option value="Student">Student</option>
                                        <option value="Instructor">Instructor</option>
                                        <option value="Admin">Admin</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Assign</button>
                                </form>
                            </td>
                            <td>
                                <a asp-action="Delete" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
