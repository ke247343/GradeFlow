@model GradeFlow.Models.Assignment
@using GradeFlow.Models

@{
    ViewData["Title"] = "Create Assignment";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h4 class="fw-bold mb-3">
                <i class="bi bi-plus-circle text-success"></i> Create New Assignment Evaluation
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3"></div>
                <input type="hidden" asp-for="CourseId" />

                <div class="row g-3 mb-3">
                    <div class="col-md-8">
                        <label asp-for="Title" class="form-label fw-semibold">Assignment Title</label>
                        <input asp-for="Title" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <!-- WEIGHT CATEGORY INPUT PICKER -->
                        <label asp-for="Category" class="form-label fw-semibold">Weighted Category Tier</label>
                        <select asp-for="Category" class="form-select" asp-items="Html.GetEnumSelectList<AssignmentCategory>()"></select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Rubric Instructions</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <label asp-for="ReleaseDate" class="form-label fw-semibold small text-muted">Visibility Release</label>
                        <input asp-for="ReleaseDate" class="form-control" type="datetime-local" value="@Model.ReleaseDate.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DueDate" class="form-label fw-semibold small text-muted">Target Due Date</label>
                        <input asp-for="DueDate" class="form-control" type="datetime-local" value="@Model.DueDate.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CutOffDate" class="form-label fw-semibold small text-muted">Absolute Lockout Cutoff</label>
                        <input asp-for="CutOffDate" class="form-control" type="datetime-local" value="@Model.CutOffDate.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="MaxPoints" class="form-label fw-semibold">Scale Max Points</label>
                        <input asp-for="MaxPoints" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AllowedFileTypes" class="form-label fw-semibold">Extensions Allowed</label>
                        <input asp-for="AllowedFileTypes" class="form-control font-monospace" required />
                    </div>
                </div>

                <div class="d-flex gap-2 border-top pt-3">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Deploy Task Matrix</button>
                    <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-secondary rounded-pill px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
