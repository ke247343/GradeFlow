@model GradeFlow.Models.Submission
@{
    ViewData["Title"] = "Grade Submission";
}

<h2>Grade Submission</h2>

<div class="card mb-3">
    <div class="card-header">
        <strong>Student:</strong> @Model.Student?.Email
    </div>
    <div class="card-body">
        <p><strong>Assignment:</strong> @Model.Assignment?.Title</p>
        <p><strong>Submitted:</strong> @Model.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</p>
        <p><strong>Late:</strong> @(Model.IsLate ? "Yes" : "No")</p>
        <p><strong>Max Points:</strong> @Model.Assignment?.MaxPoints</p>
        <p><strong>Download:</strong> <a href="@Model.FilePath" target="_blank">@System.IO.Path.GetFileName(Model.FilePath)</a></p>
    </div>
</div>

<form asp-action="Grade" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="form-group mb-3">
        <label class="control-label">Grade (0 - @Model.Assignment?.MaxPoints)</label>
        <input type="number" name="grade" class="form-control" value="@Model.Grade" min="0" max="@Model.Assignment?.MaxPoints" />
    </div>
    <div class="form-group mb-3">
        <label class="control-label">Feedback</label>
        <textarea name="feedback" class="form-control" rows="4">@Model.Feedback</textarea>
    </div>
    <div class="form-group">
        <button type="submit" class="btn btn-primary">Save Grade</button>
        <a asp-action="Index" asp-route-assignmentId="@Model.AssignmentId" class="btn btn-secondary">Cancel</a>
    </div>
</form>